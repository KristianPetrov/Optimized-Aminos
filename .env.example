# ---- Database (Neon Postgres) ----
# Get this from https://console.neon.tech (use the pooled connection string)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ---- Auth (NextAuth / Auth.js v5) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="GXRduqNlOYmPj2mqTH1h9gdtKBbv3D+bLesztUZK23k="
# Public site URL (used in emails and callbacks)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Email (Resend) ----
# Get this from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# The verified "from" address for transactional emails
EMAIL_FROM="Optimized Aminos <orders@optimizedaminos.com>"
# Where new-order notifications are sent to the shop owner
ADMIN_NOTIFICATION_EMAIL="owner@optimizedaminos.com"

# ---- Manual payment details (shown to customers at checkout) ----
NEXT_PUBLIC_ZELLE_RECIPIENT="payments@optimizedaminos.com"
NEXT_PUBLIC_VENMO_HANDLE="@OptimizedAminos"

# ---- Initial admin (used by the seed script) ----
